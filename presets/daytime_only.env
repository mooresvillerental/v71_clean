# Daytime-only notify+vibrate: quiet hours allow nothing
ALERTS_ENABLED=1
POLL_SEC=5
REPEAT_SEC=60
CURL_MAX_TIME=3
STOP_ON_CONFIRM=1

NOTIFY=1
VIBRATE=1
SPEAK=0

VIBRATE_MS=800
VIBRATE_BUY=120,120,120
VIBRATE_SELL=500,180,500

QUIET_ENABLED=1
QUIET_START=21:00
QUIET_END=08:00
QUIET_ALLOW_NOTIFY=0
QUIET_ALLOW_VIBRATE=0
QUIET_ALLOW_SPEAK=0

PRICE_MOVE_ENABLED=0
WAKE_TRADE_ENABLED=0
