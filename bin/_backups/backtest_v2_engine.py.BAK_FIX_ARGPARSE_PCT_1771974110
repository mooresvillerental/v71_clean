def _apply_fee_slip(price: float, side: str, fee_bps: float, slip_bps: float) -> float:
    # side: BUY pays up; SELL receives down
    # bps: 10 = 0.10%
    m = 1.0 + (fee_bps + slip_bps) / 10000.0
    if (side or "").upper() == "BUY":
        return float(price) * m
    return float(price) / m


